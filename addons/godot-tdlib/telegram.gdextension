[configuration]

entry_symbol = "tdjson_library_init"
compatibility_minimum = 4.5
reloadable = true

[icons]
TdJson = "icons/telegram.png"

[libraries]

windows.release.x86_64 = "bin/godot_tdlib_win_x86_64/godot_tdlib.dll"
windows.debug.x86_64 = "bin/godot_tdlib_win_x86_64/godot_tdlib_debug.dll"
linux.release.x86_64 = "bin/godot_tdlib_linux_x86_64/libgodot_tdlib.so"
linux.debug.x86_64 = "bin/godot_tdlib_linux_x86_64/libgodot_tdlib_debug.so"


[dependencies]

windows.x86_64 = {
    "bin/godot_tdlib_win_x86_64/libcrypto-3-x64.dll": "",
    "bin/godot_tdlib_win_x86_64/libssl-3-x64.dll": "",
    "bin/godot_tdlib_win_x86_64/tdjson.dll": "",
    "bin/godot_tdlib_win_x86_64/zlib1.dll": ""
}
linux.x86_64 = {
    "bin/godot_tdlib_linux_x86_64/libtdjson.so.1.8.62": ""
}
